{
    "layer": "top",
    "position": "right",
    "height": 0,
    "width": 32,
    "margin-top": 6,
    "margin-bottom": 6,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 0,
    "reload_style_on_change": true,
    "modules-left": [
        "custom/logo",
        "custom/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/opacity",
        "pulseaudio",
        "network",
        "battery",
        "custom/power"
    ],
    "custom/logo": {
        "format": "",
        "tooltip": false
    },
    "custom/workspaces": {
        "exec": "~/.config/lumie/scripts/lumie-workspaces.sh",
        "return-type": "json",
        "format": "{}",
        "markup": "pango",
        "on-click": "",
        "tooltip": true,
        "escape": false
    },
    "custom/layout": {
        "exec": "cat ${XDG_RUNTIME_DIR:-/tmp}/lumie-workspaces.json 2>/dev/null | jq -r '.workspaces[] | select(.active==true) | .layout' || echo 'Tiled'",
        "interval": 1,
        "format": " {} ",
        "tooltip": false
    },
    "custom/opacity": {
        "interval": 1,
        "exec": "cat ${XDG_RUNTIME_DIR:-/tmp}/lumie-opacity.json 2>/dev/null || echo '{\"text\":\"100%\",\"tooltip\":\"Opacity\",\"percentage\":100}'",
        "return-type": "json",
        "format": "",
        "tooltip": true,
        "on-click": "bash $HOME/.config/lumie/scripts/lumie-opacity-control.sh",
        "on-click-right": "python3 -c \"import socket,json;s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM);s.connect('/tmp/lumie.sock');s.sendall(json.dumps({'SetOpacity':{'value':1.0}}).encode());s.close()\"",
        "on-scroll-up": "python3 -c \"import socket,json;s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM);s.connect('/tmp/lumie.sock');s.sendall(json.dumps({'AdjustOpacity':{'value':0.05}}).encode());s.close()\"",
        "on-scroll-down": "python3 -c \"import socket,json;s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM);s.connect('/tmp/lumie.sock');s.sendall(json.dumps({'AdjustOpacity':{'value':-0.05}}).encode());s.close()\"",
        "escape": false
    },
    "clock": {
        "format": "{:%H}\n{:%M}",
        "format-alt": "{:%H}\n{:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },
    "pulseaudio": {
        "format": "",
        "format-bluetooth": "",
        "format-muted": "",
        "format-icons": {
            "default": [
                ""
            ]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip-format": "{desc}\n{volume}%"
    },
    "network": {
        "format-wifi": "",
        "format-ethernet": "",
        "format-disconnected": "",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}/{cidr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "",
        "format-charging": "",
        "format-plugged": "",
        "format-icons": [
            ""
        ],
        "tooltip-format": "{capacity}% — {timeTo}\n{power:.1f}W"
    },
    "custom/power": {
        "format": "",
        "tooltip": false,
        "on-click": "python3 -c \"import socket; s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM); s.connect('/tmp/lumie.sock'); s.sendall(b'\\\"Quit\\\"'); s.close()\""
    }
}
