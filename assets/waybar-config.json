{
    "layer": "top",
    "position": "top",
    "height": 38,
    "margin-top": 6,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 0,
    "reload_style_on_change": true,

    "modules-left": [
        "custom/logo",
        "custom/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/layout",
        "pulseaudio",
        "network",
        "battery",
        "custom/power"
    ],

    "custom/logo": {
        "format": "  ",
        "tooltip": false
    },

    "custom/workspaces": {
        "exec": "~/.config/mywm/scripts/mywm-workspaces.sh",
        "return-type": "json",
        "format": "{}",
        "markup": "pango",
        "on-click": "",
        "tooltip": true,
        "escape": false
    },

    "custom/layout": {
        "exec": "cat ${XDG_RUNTIME_DIR:-/tmp}/mywm-workspaces.json 2>/dev/null | jq -r '.workspaces[] | select(.active==true) | .layout' || echo 'Tiled'",
        "interval": 1,
        "format": " {} ",
        "tooltip": false
    },

    "clock": {
        "format": "  {:%H:%M}",
        "format-alt": "  {:%A, %B %d, %Y  %H:%M:%S}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "  {volume}%",
        "format-muted": "  muted",
        "format-icons": {
            "headphone": " ",
            "hands-free": " ",
            "headset": " ",
            "phone": " ",
            "portable": " ",
            "car": " ",
            "default": [" ", " ", " "]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip-format": "{desc}\n{volume}%"
    },

    "network": {
        "format-wifi": "  {signalStrength}%",
        "format-ethernet": "  {ifname}",
        "format-disconnected": "  offline",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}/{cidr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor"
    },

    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "  {capacity}%",
        "format-plugged": "  {capacity}%",
        "format-icons": [" ", " ", " ", " ", " "],
        "tooltip-format": "{timeTo}\n{power:.1f}W"
    },

    "custom/power": {
        "format": " ⏻ ",
        "tooltip": false,
        "on-click": "echo '{\"Quit\"}' | socat - UNIX-CONNECT:/tmp/mywm.sock"
    }
}