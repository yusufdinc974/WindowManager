{
    "layer": "top",
    "position": "top",
    "height": 38,
    "margin-top": 6,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 0,
    "reload_style_on_change": true,

    "modules-left": [
        "custom/logo",
        "custom/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/layout",
        "custom/opacity",
        "pulseaudio",
        "network",
        "battery",
        "custom/power"
    ],

    "custom/logo": {
        "format": "  ",
        "tooltip": false
    },

    "custom/workspaces": {
        "exec": "~/.config/mywm/scripts/mywm-workspaces.sh",
        "return-type": "json",
        "format": "{}",
        "markup": "pango",
        "on-click": "",
        "tooltip": true,
        "escape": false
    },

    "custom/layout": {
        "exec": "cat ${XDG_RUNTIME_DIR:-/tmp}/mywm-workspaces.json 2>/dev/null | jq -r '.workspaces[] | select(.active==true) | .layout' || echo 'Tiled'",
        "interval": 1,
        "format": " {} ",
        "tooltip": false
    },

    "custom/opacity": {
        "exec": "f=${XDG_RUNTIME_DIR:-/tmp}/mywm-opacity.json; if [ -f \"$f\" ]; then cat \"$f\"; else echo '{\"text\":\"100%\",\"tooltip\":\"Window Opacity\\nScroll: adjust | Click: reset\"}'; fi",
        "return-type": "json",
        "interval": 1,
        "format": "OP {}",
        "tooltip": true,
        "on-scroll-up": "python3 -c \"import socket; s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM); s.connect('/tmp/mywm.sock'); s.sendall(b'{\\\"AdjustOpacity\\\":{\\\"value\\\":0.05}}'); s.close()\"",
        "on-scroll-down": "python3 -c \"import socket; s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM); s.connect('/tmp/mywm.sock'); s.sendall(b'{\\\"AdjustOpacity\\\":{\\\"value\\\":-0.05}}'); s.close()\"",
        "on-click": "python3 -c \"import socket; s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM); s.connect('/tmp/mywm.sock'); s.sendall(b'{\\\"SetOpacity\\\":{\\\"value\\\":1.0}}'); s.close()\"",
        "on-click-right": "python3 -c \"import socket; s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM); s.connect('/tmp/mywm.sock'); s.sendall(b'{\\\"SetOpacity\\\":{\\\"value\\\":0.5}}'); s.close()\""
    },

    "clock": {
        "format": "  {:%H:%M}",
        "format-alt": "  {:%A, %B %d, %Y  %H:%M:%S}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },

    "pulseaudio": {
        "format": "VOL {volume}%",
        "format-bluetooth": "BT {volume}%",
        "format-muted": "MUTE",
        "format-icons": {
            "default": [""]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip-format": "{desc}\n{volume}%"
    },

    "network": {
        "format-wifi": "WiFi {signalStrength}%",
        "format-ethernet": "ETH {ifname}",
        "format-disconnected": "OFFLINE",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}/{cidr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor"
    },

    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "BAT {capacity}%",
        "format-charging": "CHG {capacity}%",
        "format-plugged": "PLG {capacity}%",
        "format-icons": [""],
        "tooltip-format": "{timeTo}\n{power:.1f}W"
    },

    "custom/power": {
        "format": " QUIT ",
        "tooltip": false,
        "on-click": "python3 -c \"import socket; s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM); s.connect('/tmp/mywm.sock'); s.sendall(b'\\\"Quit\\\"'); s.close()\""
    }
}