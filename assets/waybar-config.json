{
    "layer": "top",
    "position": "top",
    "height": 38,
    "margin-top": 6,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 0,
    "reload_style_on_change": true,

    "modules-left": [
        "custom/logo",
        "custom/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/layout",
        "custom/opacity",
        "pulseaudio",
        "network",
        "battery",
        "custom/power"
    ],

    "custom/logo": {
        "format": "  ",
        "tooltip": false
    },

    "custom/workspaces": {
        "exec": "~/.config/mywm/scripts/mywm-workspaces.sh",
        "return-type": "json",
        "format": "{}",
        "markup": "pango",
        "on-click": "",
        "tooltip": true,
        "escape": false
    },

    "custom/layout": {
        "exec": "cat ${XDG_RUNTIME_DIR:-/tmp}/mywm-workspaces.json 2>/dev/null | jq -r '.workspaces[] | select(.active==true) | .layout' || echo 'Tiled'",
        "interval": 1,
        "format": " {} ",
        "tooltip": false
    },

        "custom/opacity": {
        "exec": "f=${XDG_RUNTIME_DIR:-/tmp}/mywm-opacity.json; if [ -f \"$f\" ]; then cat \"$f\"; else echo '{\"text\":\"100%\",\"tooltip\":\"Opacity: 100%  Scroll to adjust\",\"percentage\":100}'; fi",
        "return-type": "json",
        "interval": 1,
        "format": "  {}",
        "tooltip": true,
        "on-scroll-up": "~/.config/mywm/scripts/mywm-ipc.sh '{\"AdjustOpacity\":{\"value\":0.05}}'",
        "on-scroll-down": "~/.config/mywm/scripts/mywm-ipc.sh '{\"AdjustOpacity\":{\"value\":-0.05}}'",
        "on-click": "~/.config/mywm/scripts/mywm-ipc.sh '{\"SetOpacity\":{\"value\":1.0}}'",
        "on-click-right": "~/.config/mywm/scripts/mywm-ipc.sh '{\"SetOpacity\":{\"value\":0.5}}'"
    },

    "clock": {
        "format": "  {:%H:%M}",
        "format-alt": "  {:%A, %B %d, %Y  %H:%M:%S}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "  {volume}%",
        "format-muted": "  muted",
        "format-icons": {
            "headphone": " ",
            "hands-free": " ",
            "headset": " ",
            "phone": " ",
            "portable": " ",
            "car": " ",
            "default": [" ", " ", " "]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip-format": "{desc}\n{volume}%"
    },

    "network": {
        "format-wifi": "󰤨  {signalStrength}%",
        "format-ethernet": "  {ifname}",
        "format-disconnected": "  offline",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}/{cidr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor"
    },

    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "  {capacity}%",
        "format-plugged": "  {capacity}%",
        "format-icons": [" ", " ", " ", " ", " "],
        "tooltip-format": "{timeTo}\n{power:.1f}W"
    },

    "custom/power": {
        "format": " ⏻ ",
        "tooltip": false,
        "on-click": "~/.config/mywm/scripts/mywm-ipc.sh '\"Quit\"'"
    }
}